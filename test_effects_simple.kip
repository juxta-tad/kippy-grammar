// Effectful functions marked with ! suffix
let print_line! = fn msg: msg

let read_file! = fn path: path

let main! = fn args: args

// Pure functions (no ! suffix)
let parse = fn text: text

let calculate = fn x: x

// Calling effectful functions with `with` syntax
let result1 = print_line! with "Hello"

let result2 = read_file! with "file.txt"

let result3 = main! with []

// Effectful functions as first-class values
let log = print_line!

// Arrays of effectful functions
let handlers = [print_line!, read_file!]
