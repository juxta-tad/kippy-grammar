type Maybe(a) =
  | Some(a)
  | None

type Result(a, e) =
  | Ok(a)
  | Err(e)

## Bare constructors as first-class values
let none_constructor = None
let some_constructor = Some

## Constructor application with `with` syntax
let value1 = Some with 42
let value2 = Ok with "success"

## Nested constructor applications
let nested = Ok with Some with 100
let error_case = Err with "oops", 500

## Pattern matching (for completeness)
let extract = fn result:
  when result is
    Ok(x) -> x
    Err(msg, code) -> 0
